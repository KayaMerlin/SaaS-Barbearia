# Copie para .env e preencha os valores
# DATABASE_URL=
# JWT_SECRET=
# FRONTEND_URL=http://localhost:3000
# PORT=4000

# Token do Mercado Pago (Credenciais > Access Token no painel MP)
# Use token de teste para desenvolvimento; em produção use o token da conta do barbeiro ou configure por tenant em Configurações.
MERCADOPAGO_ACCESS_TOKEN=
